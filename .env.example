# Copy this file to .env.dev / .env.test / .env.prod and fill in your values.

# Environment name (dev | test | prod)
ENV=dev

# PostgreSQL
POSTGRES_USER=airpulse
POSTGRES_PASSWORD=airpulse
POSTGRES_DB=airpulse_dev
DATABASE_URL=postgresql://airpulse:airpulse@db:5432/airpulse_dev

# Redis
REDIS_URL=redis://redis:6379

# API Keys — register for free at:
#   IQAir:          https://www.iqair.com/dashboard/api
#   OpenWeatherMap: https://openweathermap.org/api
IQAIR_API_KEY=your_iqair_key_here
OPENWEATHER_API_KEY=your_openweather_key_here

# Ingestion schedule (minutes between fetches)
INGESTION_INTERVAL_MINUTES=30

# Logging
LOG_LEVEL=DEBUG
